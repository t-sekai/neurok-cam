<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>DirectorWebSocketURL</key>
	<string></string>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.photography</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>AVCam uses Bluetooth to connect to external timecode generators.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>AVCam uses Bluetooth to connect to external timecode generators.</string>
	<key>NSCameraUsageDescription</key>
	<string>To capture photos and videos.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>AVCam uses your local network to receive remote recording commands from a director app.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>AVCam uses your location to tag where photos and videos are taken.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>To record audio for Live Photos and videos.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>To save captured photos and videos.</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>
	<key>UIUserInterfaceStyle</key>
	<string>Dark</string>
	<key>UILaunchScreen</key>
	<dict>
		<key>UILaunchScreen</key>
		<dict/>
	</dict>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>UIFileSharingEnabled</key>
	<true/>
</dict>
</plist>
